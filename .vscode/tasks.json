{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile LibrarySystem",
      "type": "shell",
      "command": "javac",
      "args": [
        "-encoding", "UTF-8",
        "-cp", ".;lib/*",
        "-d", "bin",
        "src/model/*.java",
        "src/view/*.java",
        "src/exception/*.java"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$javac"
    }
  ]
}